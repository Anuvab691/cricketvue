
{
  "entities": {
    "Match": {
      "title": "Match",
      "description": "A cricket match with live scoring information.",
      "type": "object",
      "properties": {
        "teamA": { "type": "string" },
        "teamB": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["upcoming", "live", "finished"] },
        "statusText": { "type": "string", "description": "The descriptive status or result of the match." },
        "currentScore": { "type": "string" },
        "venue": { "type": "string" },
        "series": { "type": "string" }
      },
      "required": ["teamA", "teamB", "startTime", "status"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile including role and token balance.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "email": { "type": "string" },
        "tokenBalance": { "type": "number" },
        "role": { "type": "string", "enum": ["admin", "super", "master", "customer"] },
        "parentId": { "type": "string", "description": "The UID of the user who created this account." },
        "isActive": { "type": "boolean" }
      }
    },
    "Bet": {
      "title": "Bet",
      "description": "A record of a bet placed by a user.",
      "type": "object",
      "properties": {
        "matchId": { "type": "string" },
        "selectionName": { "type": "string" },
        "stake": { "type": "number" },
        "odds": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "won", "lost", "cancelled"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/matches/{matchId}": {
      "schema": "#/entities/Match",
      "description": "Collection of all cricket matches."
    },
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profile data."
    },
    "/users/{userId}/bets/{betId}": {
      "schema": "#/entities/Bet",
      "description": "User's history of placed bets."
    }
  }
}
