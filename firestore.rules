
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Matches and their markets are publicly readable and writable for this prototype.
    // This allows real-time sync from the client-side action.
    match /matches/{matchId} {
      allow read, write: if true;
      
      match /markets/{marketId} {
        allow read, write: if true;
      }
    }
    
    // User profile data and their subcollections.
    // Explicitly allow authenticated users to manage their own data.
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || userId == 'guest-user-123';
      
      match /bets/{betId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || userId == 'guest-user-123';
      }
    }
    
    // Global app settings (e.g., lastGlobalSync)
    match /app_settings/{settingId} {
      allow read, write: if true;
    }
    
    // Deployment trigger comment: Policy updated to allow access to app_settings.
  }
}
