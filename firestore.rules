rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Matches and their markets are publicly readable and writable.
    // This allows the "Refresh Live Scores" action to update real-world data from the client.
    match /matches/{matchId} {
      allow read, write: if true;
      
      match /markets/{marketId} {
        allow read, write: if true;
      }
    }
    
    // User profile data and their subcollections.
    // In this prototype, we allow authenticated users to read/write their own data.
    // We also allow the guest-user-123 ID for demo purposes.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if userId == 'guest-user-123';
      
      match /bets/{betId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if userId == 'guest-user-123';
      }
    }
  }
}